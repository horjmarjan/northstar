{
  "expo": {
    "name": "NorthStar",
    "slug": "northstar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "northstar",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2EBE0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.northstar.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F2EBE0"
      },
      "package": "com.northstar.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "NorthStar uses your photo library to set a profile picture."
        }
      ]
    ]
  }
}
